GEMINI_API_KEY=
LLM_MODEL=gemini-3-flash-preview
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite:///./claims.db
LLM_RATE_LIMIT_RPM=60
LLM_REQUEST_TIMEOUT_SEC=120
API_BASE_URL=http://127.0.0.1:8000

# Streamlit: server-side HTTP calls use CLAIMS_API_URL. Optional PUBLIC_CLAIMS_API_URL is used for
# CSV/download links in the browser (set to http://localhost:8000 when Streamlit runs in Docker).
CLAIMS_API_URL=http://127.0.0.1:8000
PUBLIC_CLAIMS_API_URL=
